# MongoDB Atlas connection string for permanent storage
# Replace <username>, <password>, and <cluster-url> with your Atlas details.
MONGO_URI="mongodb+srv://<username>:<password>@<cluster-url>/ai_diet_planner?retryWrites=true&w=majority"

# Optional local MongoDB fallback for development
# If MONGO_URI is unavailable, the server will try this URI next.
MONGO_URI_LOCAL="mongodb://127.0.0.1:27017/ai_diet_planner"

# Set this to true only for temporary in-memory fallback during development.
ALLOW_MEMORY_FALLBACK=false

# JWT secret for signing tokens
JWT_SECRET=supersecret-key
JWT_EXPIRE=7d

# Optional API keys for AI features
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
